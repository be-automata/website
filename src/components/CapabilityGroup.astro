---
import SectionHeader from './SectionHeader.astro';

interface Group {
  title: string;
  items: string[];
  details?: string[];
  detailsLabel?: string;
}

interface Props {
  index?: string;
  label?: string;
  heading: string;
  headingHtml?: string;
  lead?: string;
  groups: Group[];
}

const { index = '03', label = 'Capacidades', heading, headingHtml, lead, groups } = Astro.props;
---

<section class="section section-soft">
  <SectionHeader
    index={index}
    label={label}
    title={heading}
    titleHtml={headingHtml}
    lead={lead}
  />

  <div class="shell">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        groups.map((g, i) => (
          <div class="card card-hoverable reveal">
            <div class="flex items-baseline justify-between mb-8">
              <h3 class="h-card">{g.title}</h3>
              <span class="t-mono text-[color:var(--color-ink-muted)]">
                0{i + 1}
              </span>
            </div>
            <ul class="space-y-4">
              {g.items.map((item) => (
                <li class="flex gap-4 items-start t-body">
                  <span class="t-mono text-[color:var(--color-ink-muted)] mt-1.5 min-w-[1rem]">→</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            {g.details && g.details.length > 0 && (
              <details class="capability-details mt-8 pt-6 border-t border-[color:var(--color-border)]">
                <summary class="t-mono text-[color:var(--color-ink-muted)] cursor-pointer hover:text-[color:var(--color-ink)] transition-colors">
                  {g.detailsLabel ?? 'Detalles técnicos'}
                </summary>
                <ul class="space-y-3 mt-5">
                  {g.details.map((item) => (
                    <li class="flex gap-4 items-start t-caption text-[color:var(--color-ink-muted)]">
                      <span class="t-mono mt-1 min-w-[1rem]">·</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </details>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .capability-details > summary {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .capability-details > summary::-webkit-details-marker { display: none; }
  .capability-details > summary::before {
    content: '+';
    font-family: var(--font-mono, ui-monospace, monospace);
    transition: transform 0.2s ease;
    display: inline-block;
  }
  .capability-details[open] > summary::before { content: '−'; }
</style>
