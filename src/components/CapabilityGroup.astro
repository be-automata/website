---
import SectionHeader from './SectionHeader.astro';

interface Group {
  title: string;
  items: string[];
}

interface Props {
  index?: string;
  label?: string;
  heading: string;
  headingHtml?: string;
  lead?: string;
  groups: Group[];
}

const { index = '03', label = 'Capacidades', heading, headingHtml, lead, groups } = Astro.props;
---

<section class="section section-soft">
  <SectionHeader
    index={index}
    label={label}
    title={heading}
    titleHtml={headingHtml}
    lead={lead}
  />

  <div class="shell">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        groups.map((g, i) => (
          <div class="card card-hoverable reveal">
            <div class="flex items-baseline justify-between mb-8">
              <h3 class="h-card">{g.title}</h3>
              <span class="t-mono text-[color:var(--color-ink-muted)]">
                0{i + 1}
              </span>
            </div>
            <ul class="space-y-4">
              {g.items.map((item) => (
                <li class="flex gap-4 items-start t-body">
                  <span class="t-mono text-[color:var(--color-ink-muted)] mt-1.5 min-w-[1rem]">→</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
