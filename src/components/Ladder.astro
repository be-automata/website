---
import SectionHeader from './SectionHeader.astro';

interface Tier {
  signal: string;
  diagnosis: string;
  deliverable: string;
  duration: string;
  price?: string;
}

interface Props {
  index?: string;
  label?: string;
  heading: string;
  headingHtml?: string;
  lead?: string;
  tiers: Tier[];
  cta: { label: string; href: string };
}

const {
  index = '01',
  label = 'Escalera',
  heading,
  headingHtml,
  lead,
  tiers,
  cta,
} = Astro.props;
---

<section class="section">
  <SectionHeader
    index={index}
    label={label}
    title={heading}
    titleHtml={headingHtml}
    lead={lead}
  />

  <div class="shell">
    <ol class="relative">
      {
        tiers.map((tier, i) => (
          <li class="relative reveal">
            <div class="grid grid-cols-[auto_1fr] md:grid-cols-[auto_1fr_auto] gap-x-6 md:gap-x-10 gap-y-3 py-10 border-t border-[color:var(--color-border-subtle)] group">
              {/* Oversized numeral */}
              <div class="relative min-w-[5rem] md:min-w-[7rem]">
                <span
                  class="t-ghost block leading-none select-none pointer-events-none"
                  aria-hidden="true"
                  style="font-size: clamp(4rem, 3rem + 4vw, 7rem); letter-spacing: -4px;"
                >
                  {(i + 1).toString().padStart(2, '0')}
                </span>
              </div>

              {/* Signal + diagnosis + deliverable */}
              <div class="min-w-0">
                <p class="h-card mb-4 text-balance">
                  <em>“{tier.signal}”</em>
                </p>
                <p class="t-caption mb-5 t-mono">
                  {tier.diagnosis}
                </p>
                <p class="t-body max-w-prose">{tier.deliverable}</p>
              </div>

              {/* Duration (+ optional price) */}
              <div class="md:pl-8 md:border-l md:border-[color:var(--color-border-subtle)] md:text-right flex md:flex-col gap-3 md:gap-2 items-baseline md:items-end col-span-2 md:col-span-1">
                <div class="label-upper label-upper-dark">
                  {tier.duration}
                </div>
                {
                  tier.price && (
                    <div class="t-mono text-[color:var(--color-ink)]" style="font-size: 1.0625rem;">
                      {tier.price}
                    </div>
                  )
                }
              </div>
            </div>
          </li>
        ))
      }
      <li class="border-t border-[color:var(--color-border-subtle)]" aria-hidden="true"></li>
    </ol>

    <div class="mt-14">
      <a href={cta.href} class="btn-pill-dark">
        {cta.label} <span aria-hidden="true" class="arrow">→</span>
      </a>
    </div>
  </div>
</section>
