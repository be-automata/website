---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import MaturityLadder from '@components/MaturityLadder.astro';
import CapabilityGroup from '@components/CapabilityGroup.astro';
import AntiList from '@components/AntiList.astro';
import ContactCTA from '@components/ContactCTA.astro';

const levels = [
  {
    id: 'L0',
    name: 'In heads',
    quote: 'Knowledge lives only in people\'s heads.',
    signal: 'No one can explain in writing how the process works.',
    deliverable: '3–5 day diagnosis with a prioritized plan and a clear build-vs-buy call.',
  },
  {
    id: 'L1',
    name: 'Experimenting',
    quote: 'Individual tools, nothing shared.',
    signal: 'Everyone uses Cursor or ChatGPT their own way — no shared rules, no shared conventions.',
    deliverable: 'Full review of what you\'ve already built with AI, with a clear plan for what to fix first.',
  },
  {
    id: 'L2',
    name: 'Written',
    quote: 'Your organization can describe its own work.',
    signal: 'Documents exist (written rules, registries) that capture the team\'s knowledge.',
    deliverable: 'A search system over your documents with answers that cite the source — without the AI making things up.',
  },
  {
    id: 'L3',
    name: 'In real use',
    quote: 'Your organization knows what it knows.',
    signal: 'An AI is in real use answering questions about your data — not generic data.',
    deliverable: 'AI system in real customer use, with documentation your team can read, human review before each important action, and a log of every decision.',
  },
  {
    id: 'L4',
    name: 'Watchful',
    quote: 'The system brings you things your team didn\'t see.',
    signal: 'The system proposes actions, detects what\'s unusual, and escalates hard decisions to a human.',
    deliverable: 'Continuous improvement loops, automated quality checks, and real-usage metrics.',
  },
  {
    id: 'L5',
    name: 'Improves with use',
    quote: 'The system improves with every interaction.',
    signal: 'Each new use case costs less and less to add to the system.',
    deliverable: 'Monthly retainer · one fixed point of contact · continuous capability expansion.',
  },
];

const groups = [
  {
    title: 'AI that does real work, without constant supervision',
    items: [
      'Decides what to do with each new task — without someone walking it through step by step',
      'Multiple AIs can work in parallel without stepping on each other',
      'You can stop it at any moment from where your team already works (GitHub, Linear, your tools)',
    ],
    details: [
      'Event-driven dispatch (GitHub, Linear, custom webhooks)',
      'Worktree or container isolation',
      'Skill-based routing and progressive tool disclosure',
      'Conversation compaction, stop commands, loop prevention',
    ],
    detailsLabel: 'Technical details',
  },
  {
    title: 'Finds answers in your documents — without making things up',
    items: [
      'Ask as if you were talking to a colleague who knows every one of your documents',
      'Every answer cites the source — you see where it came from, no magic',
      'Continuous quality checks — we catch when the system starts getting things wrong',
    ],
    details: [
      'Document ingestion with canonical schemas',
      'Vector stores — pgvector, Pinecone, Qdrant',
      'Source-attributed answers — no hallucination without citation',
      'Continuous evals on retrieval quality',
    ],
    detailsLabel: 'Technical details',
  },
  {
    title: 'AI that stays in its lane',
    items: [
      'Limited permissions by type, amount, and time — like a credit card with a daily limit',
      'Previews every important action before making it real',
      'You can revoke access at any moment, without calling support',
      'Visible history of every decision the system made',
    ],
    details: [
      'Scoped authority models — session keys, scopes, expiration',
      'Simulation-before-execute · rate limits · distributed locks',
      'One-click revocability · user-visible audit trails',
      'Encryption at rest · secrets management · rotation',
    ],
    detailsLabel: 'Technical details',
  },
  {
    title: 'Works where your team already works, not on a separate platform',
    items: [
      'Deploys to the cloud your company already uses — not ours',
      'Runs reliably without your team having to babysit it',
      'You can see whether it\'s healthy or something\'s wrong, at any moment',
      'Every change passes automated review before it reaches real customer use',
    ],
    details: [
      'Deploy in the customer\'s cloud (not ours)',
      'Observability — structured logs, metrics, health endpoints',
      'Resilient crons with tunable batch + concurrency',
      'CI/CD with automated review gates',
    ],
    detailsLabel: 'Technical details',
  },
];

const antiItems = [
  'We don\'t build chatbots "just to have AI".',
  'We don\'t sell proprietary platforms that lock you in.',
  'We don\'t work with clients who can\'t (or won\'t) articulate the real problem they want to solve.',
  'We don\'t promise "AI that replaces your team". We promise AI that makes your team disproportionately more effective.',
  'We never launch a system without a human approving the important steps. Never.',
];

const ctaSteps = [
  { title: 'Book a call', body: '30 minutes. We assess your case and give you a realistic timeline and architecture.' },
  { title: 'Technical proposal', body: 'Within 5 days of the call. Architecture, phases, costs, tools chosen and why.' },
  { title: 'We start', body: 'First launch in under 4 weeks from kickoff.' },
];
---

<BaseLayout
  lang="en"
  pathname="/en/capabilities"
  title="Automata — Capabilities"
  description="From knowledge that lives only in heads to systems anyone can read and review. We work at any level — from the first diagnosis to the system that improves with every use."
>
  <Hero
    variant="page"
    sectionIndex="Capabilities"
    titleHtml="AI in real customer use. <em>In weeks</em>, not quarters."
    title="AI in real customer use. In weeks, not quarters."
    lead="From knowledge that lives only in heads to systems anyone can read and review. We work at any level — from the first diagnosis to the system that improves with every use."
    primaryCta={{ label: 'See the full ladder', href: '#ladder' }}
    secondaryCta={{ label: 'Book a call', href: '#contact' }}
  />

  <div id="ladder">
    <MaturityLadder
      index="01"
      label="The ladder"
      headingHtml="Six levels — <em>from the first step to the system that improves with every use</em>."
      heading="Six levels — from the first step to the system that improves with every use."
      lead="Each level is a concrete state of the system, with signals that identify it and a deliverable that moves it to the next."
      levels={levels}
    />
  </div>

  <CapabilityGroup
    index="02"
    label="What it does for you"
    headingHtml="What a system like this can <em>do for your team</em>."
    heading="What a system like this can do for your team."
    lead="The areas we touch in most projects. Each one solves a concrete business problem — your situation picks the tools, not a closed catalog."
    groups={groups}
  />

  <section id="process" class="section">
    <div class="shell max-w-3xl reveal">
      <div class="section-index mb-8">
        <span>03</span>
        <span>·</span>
        <span>About the tools</span>
      </div>
      <h2 class="h-section mb-8">
        Every project starts with <em>one question</em>.
      </h2>
      <p class="t-body mb-8" style="font-size: 1.125rem;">
        <em>“What level are you at and which tools serve you best?”</em> The tools are a decision — not a commitment to a platform. The case studies are the evidence: each one documents what we chose, what we rejected, and why.
      </p>
      <a href="/en/cases" class="inline-flex items-center gap-2 t-caption text-[color:var(--color-ink)] border-b border-[color:var(--color-border)] pb-1 hover:border-[color:var(--color-ink)] transition-colors">
        See case studies <span aria-hidden="true" class="arrow">→</span>
      </a>
    </div>
  </section>

  <AntiList
    index="04"
    label="Constraints"
    headingHtml="What we <em>don't do</em>."
    heading="What we don't do."
    items={antiItems}
  />

  <ContactCTA
    index="05"
    label="Contact"
    id="contact"
    headingHtml="Let's talk about <em>your project</em>."
    heading="Let's talk about your project."
    steps={ctaSteps}
    primary={{ label: 'Book a discovery call', href: 'mailto:hello@beautomata.com?subject=Discovery%20call' }}
    secondary={{ label: 'Back to home', href: '/en/' }}
    footnote="No pitch, no commitment."
  />
</BaseLayout>
