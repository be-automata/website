---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Ladder from '@components/Ladder.astro';
import Stepper from '@components/Stepper.astro';
import CaseStudyGrid from '@components/CaseStudyGrid.astro';
import Pillars from '@components/Pillars.astro';
import ContactCTA from '@components/ContactCTA.astro';
import Stats from '@components/Stats.astro';
import CodeArtifact from '@components/CodeArtifact.astro';

const lang = 'en';

const stats = [
  { value: '4', label: 'Weeks', caption: 'Average time from project kickoff to first launch.' },
  { value: '18+', label: 'AI roles', caption: 'Roles ready in our open-source project orch-agents — reviewable line by line in the repo.' },
  { value: '2', label: 'In real customer use', caption: 'Systems running with real customers, open source code, and public commit history.' },
  { value: '15+', label: 'Years shipping', caption: 'We didn\'t learn AI this month. We\'ve been shipping software to real customers for fifteen years.' },
];

const workflowYaml = `templates:
  tdd-workflow:   [coder, tester]
  feature-build:  [architect, coder, reviewer]
  security-audit: [security-architect]

github:
  events:
    pull_request.opened:  github-ops
    issues.labeled.bug:   tdd-workflow
    workflow_run.failure: quick-fix

agents:
  routing:
    bug:      tdd-workflow
    feature:  feature-build
    security: security-audit
    default:  quick-fix`;

const tiers = [
  {
    signal: 'I have an idea, nothing built yet.',
    diagnosis: 'From: a loose idea. To: clarity on what to build and with what.',
    deliverable: 'Initial assessment — what to build first, a clear build-vs-buy call, and which tools to use.',
    duration: '3–5 days',
  },
  {
    signal: 'I built something with Cursor or Bolt and I\'m scared to put it in front of real customers.',
    diagnosis: 'From: a fragile prototype. To: reviewed code, ready for users.',
    deliverable: 'Full review — code, security holes, architecture, and a clear plan for what to fix first.',
    duration: '1 week',
  },
  {
    signal: 'I need an AI doing real work, not a demo.',
    diagnosis: 'From: plans on paper. To: a system running with real customers.',
    deliverable: 'Build & launch — an AI system in real customer use, with a document your team can read and maintain.',
    duration: '2–6 weeks',
  },
  {
    signal: 'It\'s live and I need it to keep improving.',
    diagnosis: 'From: a live system. To: a system that improves with every use.',
    deliverable: 'Monthly retainer — one fixed point of contact, continuous improvements, and capability expansion.',
    duration: 'monthly',
  },
];

const steps = [
  {
    label: 'Diagnose',
    title: 'We audit what already exists.',
    body: 'We look at what you have today and which processes live only in your team\'s heads. No generic questionnaires — we come to understand your system.',
  },
  {
    label: 'Structure',
    title: 'We make the unreadable readable.',
    body: 'We turn those processes into clear rules a machine (or a new hire) can follow. The first deliverable is almost always a document anyone can read and review.',
  },
  {
    label: 'Launch',
    title: 'We launch with a human in control.',
    body: 'AI systems in real customer use, with a log of every decision, limited permissions, and a preview of the result before applying. No security shortcuts.',
  },
];

const cases = [
  {
    title: 'orch-agents',
    tagline: 'A system that decides which AI handles each task on GitHub and Linear — without the criteria living only in one person\'s head.',
    problem: 'The criteria for which AI handled each task lived only in one person\'s head.',
    solution: 'A text file anyone can read and review, with full change history.',
    status: 'Open source · MIT · v0.4.0',
    href: '/en/cases/orch-agents',
  },
  {
    title: 'tapioca.money',
    tagline: 'An AI that moves real money between crypto protocols to optimize yield — with safety brakes.',
    problem: 'An AI with access to user money, with no clear brakes on what it could do if something went wrong.',
    solution: 'The AI can only move money you authorize, like a credit card with a daily limit — and previews every move before making it real.',
    status: 'In real customer use · v0.2.0',
    href: '/en/cases/tapioca',
  },
];

const pillars = [
  {
    title: 'We don\'t lock you into a platform',
    body: 'We don\'t sell you our own platform. For each project we pick the tools that serve your situation — and we explain why before writing a single line. We serve the problem, not a specific tool. The case studies show the decision in context.',
    bodyHtml: '<strong class="text-[color:var(--color-ink)] font-medium">We don\'t sell you our own platform.</strong> For each project we pick the tools that serve your situation — and we explain why before writing a single line. We serve the <em>problem</em>, not a specific tool.',
  },
  {
    title: 'Security from day one',
    body: 'Limited permissions, preview the result before applying, human review, usage controls, revocable at any moment. Not a checklist at the end — it\'s the architecture from day one.',
    bodyHtml: '<strong class="text-[color:var(--color-ink)] font-medium">Limited permissions, preview before applying, human review.</strong> Not a checklist at the end — it\'s the <em>architecture from day one</em>.',
  },
  {
    title: 'Written processes, not in heads',
    body: 'The bottleneck is rarely the AI. It\'s that your organization hasn\'t described its own work in a form a machine (or a new hire) can follow. Our first deliverable is almost always a document that turns that knowledge into something anyone can read and review.',
    bodyHtml: '<strong class="text-[color:var(--color-ink)] font-medium">The bottleneck is rarely the AI.</strong> It\'s that your organization hasn\'t described its own work in a form a machine (or a new hire) can follow. Our first deliverable is almost always a <em>document anyone can read and review</em>.',
  },
];

const ctaSteps = [
  { title: 'Book a call', body: '30 minutes. We assess your case and give you a realistic timeline and architecture.' },
  { title: 'Technical proposal', body: 'Within 5 days of the call. Architecture, phases, costs, tools chosen and why.' },
  { title: 'We start', body: 'First launch in under 4 weeks from kickoff.' },
];
---

<BaseLayout
  lang={lang}
  pathname="/en/"
  title="Automata — AI that does real work, not demos"
  description="We build AI systems that decide and act on their own — with a human approving the important steps, limited permissions, and a log of every decision. For teams about to put AI somewhere that matters."
>
  <Hero
    variant="hero"
    status="Accepting projects · ES · EN · LATAM"
    titleHtml="Is your AI ready for <em>real customers</em> — or just for the <em>demo</em>?"
    title="Is your AI ready for real customers — or just for the demo?"
    lead="We build AI systems that decide and act on their own — with a human approving every important step, limited permissions, and a log of everything they do. No shortcuts, no winging it. For teams about to put AI somewhere that matters."
    primaryCta={{ label: 'Book a discovery call', href: '#contact' }}
    secondaryCta={{ label: 'See case studies', href: '/en/cases' }}
    microline="ES · EN — Based in LATAM · 15+ years shipping software"
  />

  <Ladder
    index="01"
    label="Ladder"
    headingHtml="Where are <em>you</em>?"
    heading="Where are you?"
    lead="Nobody arrives saying “I want an AI system.” They arrive saying “I have this problem.” Find yourself in the phrase — each tier has a clear deliverable, duration, and price."
    tiers={tiers}
    cta={{ label: 'Start with a conversation', href: '#contact' }}
  />

  <Stepper
    index="02"
    headerLabel="Process"
    headingHtml="How we work — <em>three phases</em>, every project."
    heading="How we work — three phases, every project."
    principle="Start small, move fast, scale what works."
    steps={steps}
  />

  <CaseStudyGrid
    index="03"
    label="Cases"
    headingHtml="Two portfolio pieces you can <em>audit line by line</em>."
    heading="Two portfolio pieces you can audit line by line."
    lead="No client logos we can't name. Real code, commit history, changelogs. The evidence lives in the repo."
    cases={cases}
  />

  <Stats
    index="04"
    label="Evidence"
    headingHtml="The <em>numbers</em> that matter to us."
    heading="The numbers that matter to us."
    lead="Not impressions per month or “happy clients.” Delivery metrics, auditable."
    stats={stats}
  />

  <CodeArtifact
    index="05"
    label="What it looks like"
    headingHtml="The knowledge that lived in one head, now <em>lives in a file</em>."
    heading="The knowledge that lived in one head, now lives in a file."
    lead="This is a fragment of the real text file that runs orch-agents. The criteria that used to live only in one person's head — which AI handles each situation — now lives in a file anyone can read and review."
    filename="WORKFLOW.md"
    lang="yaml"
    code={workflowYaml}
    caption="Real excerpt from the repository. Full version at github.com/be-automata/orch-agents."
  />

  <Pillars
    index="06"
    headerLabel="Differentiators"
    headingHtml="What makes us <em>different</em>."
    heading="What makes us different."
    pillars={pillars}
  />

  <ContactCTA
    index="07"
    label="Contact"
    id="contact"
    headingHtml="Let's talk about <em>your project</em>."
    heading="Let's talk about your project."
    steps={ctaSteps}
    primary={{ label: 'Book a discovery call', href: 'mailto:hello@beautomata.com?subject=Discovery%20call' }}
    secondary={{ label: 'See the full process', href: '/en/capabilities' }}
    footnote="No pitch, no commitment. If we're not the match, we'll tell you who is."
  />
</BaseLayout>
