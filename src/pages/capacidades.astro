---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import MaturityLadder from '@components/MaturityLadder.astro';
import CapabilityGroup from '@components/CapabilityGroup.astro';
import AntiList from '@components/AntiList.astro';
import ContactCTA from '@components/ContactCTA.astro';

const levels = [
  {
    id: 'L0',
    name: 'En cabezas',
    quote: 'El conocimiento vive sólo en cabezas.',
    signal: 'Nadie puede explicar por escrito cómo funciona el proceso.',
    deliverable: 'Diagnóstico de 3–5 días con plan priorizado y decisión clara de construir o comprar.',
  },
  {
    id: 'L1',
    name: 'Explorando',
    quote: 'Herramientas sueltas, nada compartido.',
    signal: 'Cada quien usa Cursor o ChatGPT a su manera, sin reglas ni convenciones compartidas.',
    deliverable: 'Revisión completa de lo que ya construiste con IA, con un plan claro de qué arreglar primero.',
  },
  {
    id: 'L2',
    name: 'Escrito',
    quote: 'Tu organización puede describir su propio trabajo.',
    signal: 'Existen documentos (reglas escritas, registros) que capturan el conocimiento del equipo.',
    deliverable: 'Sistema de búsqueda en tus documentos con respuestas que citan la fuente — sin que la IA invente.',
  },
  {
    id: 'L3',
    name: 'En uso real',
    quote: 'Tu organización sabe lo que sabe.',
    signal: 'Hay una IA en uso real respondiendo preguntas sobre tus datos — no datos genéricos.',
    deliverable: 'Sistema de IA en uso real con documentación que tu equipo puede leer, revisión humana antes de cada acción importante, y registro de cada decisión.',
  },
  {
    id: 'L4',
    name: 'Atento',
    quote: 'El sistema te trae cosas que tu equipo no veía.',
    signal: 'El sistema propone acciones, detecta lo inusual, y escala las decisiones difíciles a un humano.',
    deliverable: 'Bucles de mejora continua, pruebas automáticas de calidad, y métricas de uso real.',
  },
  {
    id: 'L5',
    name: 'Mejora con cada uso',
    quote: 'El sistema mejora con cada interacción.',
    signal: 'Cada nuevo caso de uso cuesta cada vez menos sumar al sistema.',
    deliverable: 'Acompañamiento mensual · un punto de contacto fijo · expansión continua de capacidades.',
  },
];

const groups = [
  {
    title: 'IA que ejecuta trabajo real, sin supervisión constante',
    items: [
      'Decide qué hacer ante cada nueva tarea — sin que alguien tenga que indicarle paso a paso',
      'Varias IAs pueden trabajar en paralelo sin pisar el trabajo de las otras',
      'Tú puedes detenerla en cualquier momento desde donde ya trabajas (GitHub, Linear, o tu herramienta)',
    ],
    details: [
      'Event-driven dispatch (GitHub, Linear, webhooks custom)',
      'Aislamiento por worktree o contenedor',
      'Skill-based routing y progressive tool disclosure',
      'Compactación de conversación, stop commands, loop prevention',
    ],
  },
  {
    title: 'Encuentra respuestas en tus documentos — sin inventar',
    items: [
      'Pregunta como si hablaras con un colega que conoce todos tus documentos',
      'Cada respuesta cita la fuente — sabes de dónde sale, no es magia',
      'Pruebas continuas de calidad: detectamos cuándo el sistema empieza a equivocarse',
    ],
    details: [
      'Ingesta de documentos con schemas canónicos',
      'Bases vectoriales — pgvector, Pinecone, Qdrant',
      'Respuestas atribuidas a su fuente, sin alucinación sin cita',
      'Evals continuos sobre la calidad de recuperación',
    ],
  },
  {
    title: 'IA que no se sale del carril',
    items: [
      'Permisos limitados por tipo, monto, y tiempo — como una tarjeta de crédito con límite diario',
      'Prueba cada acción importante antes de hacerla real',
      'Tú puedes revocar el acceso en cualquier momento, sin llamar a soporte',
      'Historial visible de cada decisión que tomó el sistema',
    ],
    details: [
      'Modelos de autoridad acotada — session keys, scopes, expiración',
      'Simulación antes de ejecutar · rate limits · locks distribuidos',
      'Revocabilidad en un click · audit trails visibles al usuario',
      'Cifrado en reposo · manejo de secretos · rotación',
    ],
  },
  {
    title: 'Funciona donde ya trabajas, no en una plataforma aparte',
    items: [
      'Se despliega en la cloud que tu empresa ya usa — no en una nuestra',
      'Funciona de forma confiable sin que tu equipo lo esté vigilando',
      'Ves en todo momento si está sano o si algo va mal',
      'Cada cambio pasa por revisión automática antes de llegar a uso real',
    ],
    details: [
      'Despliegue en cloud del cliente (no el mío)',
      'Observabilidad — logs estructurados, métricas, health endpoints',
      'Crons resilientes con batch + concurrencia ajustables',
      'CI/CD con puertas de revisión automatizadas',
    ],
  },
];

const antiItems = [
  'No construimos chatbots "para tener IA".',
  'No vendemos plataformas propias que te encadenen a nosotros.',
  'No trabajamos con clientes que no pueden (o no quieren) articular qué problema real quieren resolver.',
  'No prometemos "IA que reemplaza a tu equipo". Prometemos IA que hace que tu equipo sea desproporcionadamente más efectivo.',
  'Nunca lanzamos un sistema sin que un humano apruebe los pasos importantes. Nunca.',
];

const ctaSteps = [
  { title: 'Agenda una llamada', body: '30 minutos. Evaluamos tu caso, te damos un timeline y una arquitectura realista.' },
  { title: 'Propuesta técnica', body: 'En 5 días desde la llamada. Arquitectura, fases, costes, herramientas elegidas y por qué.' },
  { title: 'Empezamos', body: 'Primer lanzamiento en menos de 4 semanas desde el arranque.' },
];
---

<BaseLayout
  lang="es"
  pathname="/capacidades"
  title="Automata — Capacidades"
  description="De conocimiento que vive en cabezas a sistemas que cualquiera puede leer y revisar. Trabajamos en cualquier nivel — desde el primer diagnóstico hasta el sistema que mejora con cada uso."
>
  <Hero
    variant="page"
    sectionIndex="Capacidades"
    titleHtml="IA en uso real con clientes. <em>En semanas</em>, no en trimestres."
    title="IA en uso real con clientes. En semanas, no en trimestres."
    lead="De conocimiento que vive sólo en cabezas a sistemas que cualquiera puede leer y revisar. Trabajamos en cualquier nivel — desde el primer diagnóstico hasta el sistema que mejora con cada uso."
    primaryCta={{ label: 'Ver la escalera completa', href: '#escalera' }}
    secondaryCta={{ label: 'Agendar llamada', href: '#contacto' }}
  />

  <div id="escalera">
    <MaturityLadder
      index="01"
      label="La escalera"
      headingHtml="Seis niveles — <em>del primer paso al sistema que mejora con cada uso</em>."
      heading="Seis niveles — del primer paso al sistema que mejora con cada uso."
      lead="Cada nivel es un estado concreto del sistema, con señales que lo identifican y un entregable que lo mueve al siguiente."
      levels={levels}
    />
  </div>

  <CapabilityGroup
    index="02"
    label="Lo que hace por ti"
    headingHtml="Lo que un sistema así puede <em>hacer por tu equipo</em>."
    heading="Lo que un sistema así puede hacer por tu equipo."
    lead="Las áreas que tocamos en la mayoría de proyectos. Cada una resuelve un problema concreto del negocio — las herramientas las elige tu situación, no un catálogo cerrado."
    groups={groups}
  />

  <section id="proceso" class="section">
    <div class="shell max-w-3xl reveal">
      <div class="section-index mb-8">
        <span>03</span>
        <span>·</span>
        <span>Sobre las herramientas</span>
      </div>
      <h2 class="h-section mb-8">
        Cada proyecto empieza con <em>una pregunta</em>.
      </h2>
      <p class="t-body mb-8" style="font-size: 1.125rem;">
        <em>“¿En qué nivel estás y qué herramientas te sirven mejor?”</em> Las herramientas son una decisión — no un compromiso con una plataforma. Los casos de estudio son la evidencia: cada uno documenta qué elegimos, qué desechamos, y por qué.
      </p>
      <a href="/casos" class="inline-flex items-center gap-2 t-caption text-[color:var(--color-ink)] border-b border-[color:var(--color-border)] pb-1 hover:border-[color:var(--color-ink)] transition-colors">
        Ver casos de estudio <span aria-hidden="true" class="arrow">→</span>
      </a>
    </div>
  </section>

  <AntiList
    index="04"
    label="Restricciones"
    headingHtml="Lo que <em>no hacemos</em>."
    heading="Lo que no hacemos."
    items={antiItems}
  />

  <ContactCTA
    index="05"
    label="Contacto"
    id="contacto"
    headingHtml="Hablemos de <em>tu proyecto</em>."
    heading="Hablemos de tu proyecto."
    steps={ctaSteps}
    primary={{ label: 'Agendar llamada de descubrimiento', href: 'mailto:hello@beautomata.com?subject=Llamada%20de%20descubrimiento' }}
    secondary={{ label: 'Volver al inicio', href: '/' }}
    footnote="Sin pitch, sin compromiso."
  />
</BaseLayout>
