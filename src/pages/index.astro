---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Ladder from '@components/Ladder.astro';
import Stepper from '@components/Stepper.astro';
import CaseStudyGrid from '@components/CaseStudyGrid.astro';
import Pillars from '@components/Pillars.astro';
import ContactCTA from '@components/ContactCTA.astro';
import Stats from '@components/Stats.astro';
import CodeArtifact from '@components/CodeArtifact.astro';

const lang = 'es';

const stats = [
  { value: '4', label: 'Semanas', caption: 'Tiempo medio hasta el primer lanzamiento desde el arranque del proyecto.' },
  { value: '18+', label: 'Roles de IA', caption: 'Roles listos en nuestro proyecto abierto orch-agents, revisables línea por línea en el repositorio.' },
  { value: '2', label: 'En uso real', caption: 'Sistemas funcionando con clientes reales, código abierto e historial público de cambios.' },
  { value: '15+', label: 'Años entregando', caption: 'No aprendimos IA este mes. Llevamos quince años entregando software a clientes reales.' },
];

const workflowYaml = `templates:
  tdd-workflow:   [coder, tester]
  feature-build:  [architect, coder, reviewer]
  security-audit: [security-architect]

github:
  events:
    pull_request.opened:  github-ops
    issues.labeled.bug:   tdd-workflow
    workflow_run.failure: quick-fix

agents:
  routing:
    bug:      tdd-workflow
    feature:  feature-build
    security: security-audit
    default:  quick-fix`;

const tiers = [
  {
    signal: 'Tengo una idea, todavía no he construido nada.',
    diagnosis: 'De: una idea suelta. A: claridad de qué construir y con qué.',
    deliverable: 'Diagnóstico inicial — qué construir primero, decisión clara de construir o comprar, y qué herramientas usar.',
    duration: '3–5 días',
  },
  {
    signal: 'Probé algo con Cursor o Bolt y me da miedo lanzarlo a clientes reales.',
    diagnosis: 'De: prototipo frágil. A: código revisado y listo para usuarios.',
    deliverable: 'Revisión completa — código, agujeros de seguridad, arquitectura, y plan claro de qué arreglar primero.',
    duration: '1 semana',
  },
  {
    signal: 'Necesito una IA que haga este trabajo real, no una demo.',
    diagnosis: 'De: planos sobre papel. A: un sistema funcionando con clientes reales.',
    deliverable: 'Construir y lanzar — un sistema de IA en uso real, con un documento que tu equipo puede leer y mantener.',
    duration: '2–6 semanas',
  },
  {
    signal: 'Ya está vivo y necesito que siga mejorando.',
    diagnosis: 'De: sistema vivo. A: sistema que mejora con cada uso.',
    deliverable: 'Acompañamiento mensual — un punto de contacto fijo, mejoras continuas, y expansión de capacidades.',
    duration: 'mensual',
  },
];

const steps = [
  {
    label: 'Diagnosticar',
    title: 'Revisamos lo que ya existe.',
    body: 'Vemos qué tienes hoy y qué procesos viven sólo en la cabeza de tu equipo. Sin preguntas genéricas — venimos a entender tu sistema.',
  },
  {
    label: 'Estructurar',
    title: 'Hacemos legible lo que no lo era.',
    body: 'Convertimos esos procesos en reglas claras que una máquina (o una persona nueva) puede seguir. El primer entregable casi siempre es un documento que cualquiera puede leer y revisar.',
  },
  {
    label: 'Lanzar',
    title: 'Lanzamos con un humano en el control.',
    body: 'Sistemas de IA en uso real con registro de cada decisión, permisos limitados, y prueba del resultado antes de aplicarlo. Sin atajos en seguridad.',
  },
];

const cases = [
  {
    title: 'orch-agents',
    tagline: 'Sistema que decide qué IA atiende cada tarea en GitHub y Linear — sin que el conocimiento viva en la cabeza de una persona.',
    problem: 'El criterio de qué IA atendía cada tarea vivía sólo en la cabeza de una persona del equipo.',
    solution: 'Un archivo de texto que cualquiera puede leer y revisar, con historial completo de cambios.',
    status: 'Código abierto · MIT · v0.4.0',
    href: '/casos/orch-agents',
  },
  {
    title: 'tapioca.money',
    tagline: 'Una IA que mueve dinero real entre protocolos cripto para optimizar rendimientos — con frenos de seguridad.',
    problem: 'Una IA con acceso a dinero del usuario, sin frenos claros sobre qué podía hacer si algo salía mal.',
    solution: 'La IA sólo puede mover el dinero que autorizas, como una tarjeta de crédito con límite — y prueba cada movimiento antes de hacerlo real.',
    status: 'En uso real · v0.2.0',
    href: '/casos/tapioca',
  },
];

const pillars = [
  {
    title: 'No te encadenamos a una plataforma',
    body: 'No te vendemos una plataforma propia. Para cada proyecto elegimos las herramientas que sirven a tu situación — y te explicamos por qué antes de escribir una línea. Servimos al problema, no a una herramienta concreta. Los casos de estudio muestran la decisión en contexto.',
    bodyHtml: '<strong class="text-[color:var(--color-ink)] font-medium">No te vendemos una plataforma propia.</strong> Para cada proyecto elegimos las herramientas que sirven a tu situación — y te explicamos por qué antes de escribir una línea. Servimos al <em>problema</em>, no a una herramienta concreta.',
  },
  {
    title: 'Seguridad desde el primer día',
    body: 'Permisos limitados, prueba del resultado antes de aplicarlo, revisión humana, controles de uso, revocable en cualquier momento. No es un checklist al final — es la arquitectura desde el día uno.',
    bodyHtml: '<strong class="text-[color:var(--color-ink)] font-medium">Permisos limitados, prueba antes de aplicar, revisión humana.</strong> No es un checklist al final — es la <em>arquitectura desde el día uno</em>.',
  },
  {
    title: 'Procesos escritos, no en cabezas',
    body: 'El cuello de botella rara vez es la IA. Es que tu organización no ha descrito su propio trabajo en una forma que una máquina (o una persona nueva) pueda seguir. Nuestro primer entregable casi siempre es un documento que vuelve ese conocimiento revisable por cualquiera.',
    bodyHtml: '<strong class="text-[color:var(--color-ink)] font-medium">El cuello de botella rara vez es la IA.</strong> Es que tu organización no ha descrito su propio trabajo en una forma que una máquina (o una persona nueva) pueda seguir. Nuestro primer entregable casi siempre es un <em>documento que cualquiera puede leer y revisar</em>.',
  },
];

const ctaSteps = [
  { title: 'Agenda una llamada', body: '30 minutos. Evaluamos tu caso, te damos un timeline y una arquitectura realista.' },
  { title: 'Propuesta técnica', body: 'En 5 días desde la llamada. Arquitectura, fases, costes, herramientas elegidas y por qué.' },
  { title: 'Empezamos', body: 'Primer lanzamiento en menos de 4 semanas desde el arranque.' },
];
---

<BaseLayout
  lang={lang}
  pathname="/"
  title="Automata — IA que ejecuta trabajo real, no demos"
  description="Construimos sistemas de IA que toman decisiones y ejecutan trabajo real — con un humano que aprueba los pasos importantes, permisos limitados, y registro de cada decisión. Para equipos que van a poner IA donde importa."
>
  <Hero
    variant="hero"
    status="Aceptando proyectos · ES · EN · LATAM"
    titleHtml="¿Tu IA está lista para <em>uso real con clientes</em> — o sólo para la <em>demo</em>?"
    title="¿Tu IA está lista para uso real con clientes — o sólo para la demo?"
    lead="Construimos sistemas de IA que toman decisiones por sí mismos — con un humano que aprueba antes de cada acción importante, permisos limitados, y registro de todo lo que hacen. Sin atajos, sin improvisar. Para equipos que van a poner IA donde importa."
    primaryCta={{ label: 'Agendar llamada de descubrimiento', href: '#contacto' }}
    secondaryCta={{ label: 'Ver casos de estudio', href: '/casos' }}
    microline="ES · EN — Basado en LATAM · 15+ años entregando software"
  />

  <Ladder
    index="01"
    label="Escalera"
    headingHtml="¿Por dónde <em>estás</em>?"
    heading="¿Por dónde estás?"
    lead="Nadie llega diciendo “quiero un sistema de IA”. Llegan diciendo “tengo este problema”. Identifícate en la frase — cada nivel tiene un entregable con precio y duración claros."
    tiers={tiers}
    cta={{ label: 'Empezar con una conversación', href: '#contacto' }}
  />

  <Stepper
    index="02"
    headerLabel="Proceso"
    headingHtml="Cómo trabajamos — <em>tres fases</em>, cada proyecto."
    heading="Cómo trabajamos — tres fases, cada proyecto."
    principle="Empezar pequeño, moverse rápido, escalar lo que funciona."
    steps={steps}
  />

  <CaseStudyGrid
    index="03"
    label="Casos"
    headingHtml="Dos piezas de portfolio que puedes <em>auditar línea por línea</em>."
    heading="Dos piezas de portfolio que puedes auditar línea por línea."
    lead="No logos de clientes que no puedo nombrar. Código real, commit history, changelogs. La evidencia vive en el repo."
    cases={cases}
  />

  <Stats
    index="04"
    label="Evidencia"
    headingHtml="Los <em>números</em> que me importan."
    heading="Los números que nos importan."
    lead="No impresiones por mes ni “clientes satisfechos”. Métricas de entrega, auditables."
    stats={stats}
  />

  <CodeArtifact
    index="05"
    label="Cómo se ve"
    headingHtml="El conocimiento que vivía en una cabeza, ahora <em>vive en un archivo</em>."
    heading="El conocimiento que vivía en una cabeza, ahora vive en un archivo."
    lead="Este es un fragmento del archivo de texto real que dirige orch-agents. El criterio que antes vivía sólo en la cabeza de una persona — qué IA atiende cada situación — ahora vive en un archivo que cualquiera puede leer y revisar."
    filename="WORKFLOW.md"
    lang="yaml"
    code={workflowYaml}
    caption="Extracto real del repositorio. Ver la versión completa en github.com/be-automata/orch-agents."
  />

  <Pillars
    index="06"
    headerLabel="Diferenciadores"
    headingHtml="Qué nos hace <em>diferente</em>."
    heading="Qué nos hace diferente."
    pillars={pillars}
  />

  <ContactCTA
    index="07"
    label="Contacto"
    id="contacto"
    headingHtml="Hablemos de <em>tu proyecto</em>."
    heading="Hablemos de tu proyecto."
    steps={ctaSteps}
    primary={{ label: 'Agendar llamada de descubrimiento', href: 'mailto:hello@beautomata.com?subject=Llamada%20de%20descubrimiento' }}
    secondary={{ label: 'Ver el proceso completo', href: '/capacidades' }}
    footnote="Sin pitch, sin compromiso. Si no somos el match, te decimos quién sí lo es."
  />
</BaseLayout>
