---
import '@styles/global.css';
import Navigation from '@components/Navigation.astro';
import Footer from '@components/Footer.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  pathname: string;
}

const { title, description, lang, pathname } = Astro.props;
const altLangHref = lang === 'es' ? `/en${pathname === '/' ? '' : pathname}` : pathname.replace(/^\/en/, '') || '/';

const canonical = new URL(pathname, Astro.site ?? 'https://www.beautomata.com').toString();
const ogImage = new URL('/og-default.png', Astro.site ?? 'https://www.beautomata.com').toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="light" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" hreflang={lang === 'es' ? 'en' : 'es'} href={altLangHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Automata" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Automata — Agentes de IA en producción" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Automata — Agentes de IA en producción" />

    <title>{title}</title>
  </head>
  <body>
    <Navigation lang={lang} pathname={pathname} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
